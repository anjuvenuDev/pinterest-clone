# Set one API URL depending on where the app runs.
# iOS simulator / web:
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
# Android emulator alternative:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000/api
# Physical device alternative (replace with your laptop LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:8000/api

EXPO_PUBLIC_DEMO_TOKEN=demo-token
